---
/**
 * Header.astro — sticky top bar, nav, mobile burger, phone CTA. Reads SITE + SERVICES.
 */
import { SITE, tel } from '@config/site';
import { SERVICES } from '@config/services';
import { serviceUrl } from '../lib/urls';
---

<header class="site-header">
  <div class="container bar">
    <a href="/" class="brand" aria-label={`${SITE.company} home`}>
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="brand-text">
        <strong>{SITE.company}</strong>
        <small>{SITE.tagline}</small>
      </span>
    </a>

    <button class="burger" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="site-nav">
      <span></span><span></span><span></span>
    </button>

    <nav class="site-nav" id="site-nav">
      <a href="/">Home</a>
      {SERVICES.map((s) => <a href={serviceUrl(s)}>{s.short}</a>)}
      <a href="/service-area/augusta/">Service Area</a>
      <a class="btn btn-call btn-sm nav-call" href={tel()}>📞 {SITE.phoneDisplay}</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    background: var(--paper);
    border-bottom: 2px solid var(--navy);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    min-height: 64px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--navy);
  }
  .brand-mark {
    width: 26px;
    height: 26px;
    background: var(--green);
    flex: none;
  }
  .brand-text strong {
    display: block;
    font-size: 1.05rem;
    line-height: 1.1;
  }
  .brand-text small {
    display: block;
    color: var(--ink-soft);
    font-size: 0.78rem;
  }
  .site-nav {
    display: flex;
    align-items: center;
    gap: 6px 18px;
    flex-wrap: wrap;
  }
  .site-nav > a:not(.btn) {
    color: var(--navy);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 6px 2px;
  }
  .site-nav > a:not(.btn):hover {
    color: var(--green-dark);
  }
  .nav-call {
    margin-left: 6px;
  }
  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .burger span {
    width: 24px;
    height: 2px;
    background: var(--navy);
    border-radius: 2px;
  }

  @media (max-width: 920px) {
    .burger {
      display: flex;
    }
    .site-nav {
      display: none;
      position: absolute;
      left: 0;
      right: 0;
      top: 100%;
      background: var(--paper);
      border-bottom: 1px solid var(--line);
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 8px 24px 20px;
    }
    .site-nav.open {
      display: flex;
    }
    .site-nav > a:not(.btn) {
      padding: 12px 0;
      border-bottom: 1px solid var(--line);
    }
    .nav-call {
      margin: 14px 0 0;
      justify-content: center;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const nav = document.getElementById('site-nav');
  toggle?.addEventListener('click', () => {
    const open = nav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
</script>
