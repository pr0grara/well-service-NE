---
/**
 * QuoteForm.astro — primary lead-capture form.
 * Backend is chosen in site.ts:
 *   - Web3Forms: formEndpoint = api.web3forms.com/submit + formAccessKey
 *   - Formspree:  formEndpoint = formspree.io/f/xxxx (no key)
 *   - Worker/custom: any endpoint accepting multipart/form-data POST → 2xx
 *   - Call-only:  formEndpoint = "" → submit disabled, shows "call us instead"
 */
import { SITE, tel } from '@config/site';

interface Props {
  source?: string;
  heading?: string;
  sub?: string;
}
const {
  source = 'website',
  heading = 'Request a Free Quote',
  sub = 'Tell us what your well is doing and we’ll call you back — usually same day.',
} = Astro.props;

const subject = `New lead — ${SITE.company} (${source})`;
---

<div class="card quote-form" id="quote">
  <h3>{heading}</h3>
  <p class="muted">{sub}</p>

  <form id="lead-form" novalidate>
    {SITE.formAccessKey ? <input type="hidden" name="access_key" value={SITE.formAccessKey} /> : null}
    <input type="hidden" name="source" value={source} />
    <input type="hidden" name="subject" value={subject} />
    <input type="hidden" name="from_name" value={SITE.company} />

    <!-- honeypot: real people leave this empty -->
    <div class="hp" aria-hidden="true">
      <label>Company Website<input type="text" name="company_website" tabindex="-1" autocomplete="off" /></label>
    </div>

    <div class="field">
      <label for="lf-name">Name <span class="req">*</span></label>
      <input id="lf-name" name="name" type="text" autocomplete="name" required />
    </div>
    <div class="field">
      <label for="lf-phone">Phone</label>
      <input id="lf-phone" name="phone" type="tel" autocomplete="tel" inputmode="tel" />
    </div>
    <div class="field">
      <label for="lf-email">Email <span class="req">*</span></label>
      <input id="lf-email" name="email" type="email" autocomplete="email" required />
    </div>
    <div class="field">
      <label for="lf-message">What’s going on with your well?</label>
      <textarea id="lf-message" name="message" rows="4" placeholder="No water, low pressure, staining, frozen line…"></textarea>
    </div>

    <button type="submit" class="btn btn-primary btn-lg btn-block" id="lf-submit">
      Send My Request
    </button>
    <p class="form-status" id="form-status" role="status" aria-live="polite"></p>

    <p class="muted or-call">
      Prefer to talk now? Call <a href={tel()}>{SITE.phoneDisplay}</a>.
    </p>
  </form>
</div>

<style>
  .quote-form h3 {
    margin-bottom: 4px;
  }
  .or-call {
    margin: 14px 0 0;
    text-align: center;
  }
</style>

<script>
  const form = document.getElementById('lead-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('form-status');
  if (form && statusEl) {
    const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const field = (name: string) => form.elements.namedItem(name) as HTMLInputElement | null;

    const setStatus = (msg: string, kind?: 'ok' | 'err') => {
      statusEl.textContent = msg;
      statusEl.className = 'form-status' + (kind ? ' ' + kind : '');
    };

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      // honeypot — bots fill this; bail silently as if successful
      const hp = field('company_website');
      if (hp && hp.value.trim() !== '') {
        setStatus('Thanks — we’ll be in touch shortly.', 'ok');
        form.reset();
        return;
      }

      const nameEl = field('name');
      const emailEl = field('email');
      if (!nameEl || !nameEl.value.trim()) {
        setStatus('Please enter your name.', 'err');
        nameEl?.focus();
        return;
      }
      if (!emailEl || !emailRe.test(emailEl.value.trim())) {
        setStatus('Please enter a valid email address.', 'err');
        emailEl?.focus();
        return;
      }

      // No backend wired up yet — acknowledge on the page without sending anything.
      setStatus('Thanks — we got your request and will call you back shortly.', 'ok');
      form.reset();
    });
  }
</script>
