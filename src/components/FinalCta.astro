---
/**
 * FinalCta.astro — bottom call/quote band.
 */
import { SITE, tel } from '@config/site';

interface Props {
  heading?: string;
  sub?: string;
}
const {
  heading = `Well Trouble in ${SITE.region}? Let’s Fix It.`,
  sub = 'Call now for a straight answer and an up-front price — no water and frozen-line calls get priority.',
} = Astro.props;
---

<section class="final-cta">
  <div class="container">
    <h2>{heading}</h2>
    <p>{sub}</p>
    <div class="cta-actions">
      <a class="btn btn-call btn-lg" href={tel()}>📞 Call {SITE.phoneDisplay}</a>
      <a class="btn btn-outline btn-lg" href="#quote">Request a Quote</a>
    </div>
  </div>
</section>

<style>
  .final-cta {
    background: var(--navy);
    color: #efe9dc;
    padding: 64px 0;
    text-align: center;
  }
  .final-cta h2 {
    color: #f6f1e6;
  }
  .final-cta p {
    color: rgba(243, 238, 227, 0.9);
    max-width: 56ch;
    margin: 0 auto 24px;
    font-size: 1.1rem;
  }
  .cta-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
