---
/**
 * BrandMark.astro — Pine State Well & Pump logo mark.
 * A simple layered pine (the "Pine State") rising out of a drop of well water.
 * Monochrome-friendly, scales cleanly. Pass `size` (px) to resize.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 30, class: className } = Astro.props;
---

<svg
  class:list={['brand-mark', className]}
  width={size}
  height={size}
  viewBox="0 0 48 48"
  role="img"
  aria-label="Pine State Well and Pump"
  focusable="false"
>
  <!-- water drop the pine sits in -->
  <path
    d="M24 5C24 5 38 21 38 31a14 14 0 0 1-28 0C10 21 24 5 24 5Z"
    fill="#1c6ea4"
  />
  <!-- pine tree -->
  <g fill="#ffffff">
    <rect x="22.6" y="33" width="2.8" height="6" rx="0.6" />
    <polygon points="24,13 30,22 18,22" />
    <polygon points="24,18.5 32,29 16,29" />
    <polygon points="24,24 34.5,35 13.5,35" />
  </g>
</svg>
